.env
.env.local
openapi.json
tests/ci_results.txt

# Runtime state (SQLite db, Qdrant volumes, VRAM observed costs)
data/*
!data/.gitkeep
# Vendored eval benchmarks ship with the repo so `scripts/eval_tiers.py`
# runs offline. The datasets/ subdir is checked in; results/ + logs/ are
# generated output and stay ignored.
!data/eval/
data/eval/*
!data/eval/datasets/
!data/eval/datasets/**
!data/eval/README.md

# Downloaded model files (GGUF + mmproj for llama.cpp vision tier)
models/*
!models/.gitkeep

# Frontend build artifacts
frontend/node_modules/
frontend/dist/
frontend/package-lock.json

# Docker override files
docker-compose.override.yml

# Local config overrides
config/local.yaml

# Vendor binaries + Python venvs (created by LocalAIStack.ps1 -Setup).
# qdrant.exe, llama-server.exe, cloudflared.exe, plus venv-backend /
# venv-gui / venv-jupyter — each ~250 MB of pip-installed packages.
vendor/

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Launcher build output (compiled ps2exe binaries)
launcher/dist/

# Logs
*.log
