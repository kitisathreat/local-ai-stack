# Copy this file to .env.local and fill in the blanks.
# .env.local is gitignored.

# ── Auth (required) ──────────────────────────────────────────────────────────
# Session JWT signing key. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
AUTH_SECRET_KEY=

# ── Chat-history encryption key (optional) ──────────────────────────────────
# The backend encrypts per-user chat history at rest with AES-256-GCM, using
# a key derived via HKDF-SHA256 from this KEK (or AUTH_SECRET_KEY if unset).
# Set this explicitly if you want to rotate AUTH_SECRET_KEY without making
# existing encrypted history files unreadable. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
HISTORY_SECRET_KEY=

# Public URL users will click the magic-link from. For local-only, leave
# http://localhost:3000. For a Cloudflare Tunnel hostname, use the public
# HTTPS URL.
PUBLIC_BASE_URL=http://localhost:3000

# ── SMTP (optional — falls back to logging links to backend stdout) ──────────
# When unset, magic links are printed to `docker logs backend` instead of
# being emailed. Useful for local development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_STARTTLS=true
AUTH_EMAIL_FROM=noreply@yourdomain.tld

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to hit /api/*. Use * for development;
# restrict to your Cloudflare hostname for production.
ALLOWED_ORIGINS=*

# ── Cloudflare Tunnel (optional public HTTPS) ────────────────────────────────
# Run `bash scripts/setup-cloudflared.sh` to provision. Once set, start the
# tunnel with: `docker compose --profile public up -d cloudflared`
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_HOSTNAME=

# ── Ollama tuning (optional) ─────────────────────────────────────────────────
OLLAMA_KEEP_ALIVE=30m
OLLAMA_MAX_LOADED_MODELS=3
OLLAMA_NUM_PARALLEL=3
# Flash Attention 2 — faster prefill and lower KV-cache VRAM on Ampere+ GPUs.
# Set to 0 to disable (e.g. on older cards that don't support FA2).
OLLAMA_FLASH_ATTENTION=1

# ── Jupyter sidecar (required) ───────────────────────────────────────────────
# Auth token for the Jupyter kernel that the coding tier uses. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
# The token is never published on a host port — the backend reaches Jupyter
# over the internal compose network only.
JUPYTER_TOKEN=

# ── n8n basic auth (required for the n8n sidecar) ────────────────────────────
# Set a username + password so the workflow UI is gated. n8n is bound to
# 127.0.0.1 so only local callers can reach it even with these set.
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# ── Trusted reverse-proxy(ies) for client-IP resolution ──────────────────────
# Comma-separated list of IPs or CIDRs whose X-Forwarded-For headers we
# trust. Leave unset for direct-peer deployments; set this when the
# backend sits behind Cloudflare Tunnel, nginx, etc. Example:
#   TRUSTED_PROXIES=127.0.0.1,::1,10.0.0.0/8
TRUSTED_PROXIES=
# When running behind a Cloudflare Tunnel container on localhost, this
# flag tells the backend to also treat CF-Connecting-IP as authoritative.
CLOUDFLARE_TUNNEL_ENABLED=0

# ── Misc (optional) ──────────────────────────────────────────────────────────
# Log the FULL magic-link verify URL to backend stdout when SMTP isn't
# configured. DANGEROUS — the URL grants sign-in. Leave unset in any
# deployment where log access isn't fully trusted.
AUTH_DEV_LINK_LOG=0
# Override the default Content-Security-Policy. Set to "off" to disable
# the CSP header entirely (not recommended in production).
CSP_HEADER=
# Bound on in-flight fire-and-forget finalization tasks (distillation,
# history append). Raise carefully; each unit holds a Versatile-tier
# slot briefly.
FINALIZE_MAX_CONCURRENCY=8
LOG_LEVEL=INFO
