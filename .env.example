# Copy this file to .env.local and fill in the blanks.
# .env.local is gitignored.

# ── Auth (required) ──────────────────────────────────────────────────────────
# Session JWT signing key. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
AUTH_SECRET_KEY=

# ── Admin dashboard access ──────────────────────────────────────────────────
# Comma-separated list of email addresses allowed into the /admin dashboard
# and the per-chat multi-agent override panel. When unset, /admin returns 503.
# setup.ps1 -Interactive prompts for this on Windows. Magic-link login uses
# whatever email you sign in with — only addresses listed here get admin.
ADMIN_EMAILS=

# ── Chat-history encryption key (recommended) ───────────────────────────────
# The backend encrypts per-user chat history at rest with AES-256-GCM, using
# a key derived via HKDF-SHA256 from this KEK (or AUTH_SECRET_KEY if unset).
# Set this explicitly if you want to rotate AUTH_SECRET_KEY without making
# existing encrypted history files unreadable. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
HISTORY_SECRET_KEY=

# ── Jupyter sandbox token (required) ────────────────────────────────────────
# Token for the Jupyter code-interpreter container. Leaving this empty leaves
# the Jupyter API on :8888 unauthenticated; the startup diagnostics flag this
# as a security ERROR. setup.ps1 generates one automatically. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
JUPYTER_TOKEN=

# Public URL users will click the magic-link from. For local-only, leave
# http://localhost:3000. For a Cloudflare Tunnel hostname, use the public
# HTTPS URL.
PUBLIC_BASE_URL=http://localhost:3000

# ── SMTP (optional — falls back to logging links to backend stdout) ──────────
# When unset, magic links are printed to `docker logs backend` instead of
# being emailed. Useful for local development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_STARTTLS=true
AUTH_EMAIL_FROM=noreply@yourdomain.tld

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to hit /api/*. Use * for development;
# restrict to your Cloudflare hostname for production.
ALLOWED_ORIGINS=*

# ── Cloudflare Tunnel (optional public HTTPS) ────────────────────────────────
# Run `bash scripts/setup-cloudflared.sh` to provision. Once set, start the
# tunnel with: `docker compose --profile public up -d cloudflared`
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_HOSTNAME=

# ── Ollama tuning (optional) ─────────────────────────────────────────────────
OLLAMA_KEEP_ALIVE=30m
OLLAMA_MAX_LOADED_MODELS=3
OLLAMA_NUM_PARALLEL=3
# Flash Attention 2 — faster prefill and lower KV-cache VRAM on Ampere+ GPUs.
# Set to 0 to disable (e.g. on older cards that don't support FA2).
OLLAMA_FLASH_ATTENTION=1

# ── Misc (optional) ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
