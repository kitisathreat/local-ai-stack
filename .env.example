# Copy to .env and fill in. .env is gitignored.

# ── Cloudflare Access (required for production) ───────────────────────────────
# From Cloudflare Zero Trust → Access → Applications → your app → Overview
CF_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com
CF_ACCESS_AUD=abc123...

# ── Dev-only bypass (leave empty in production) ───────────────────────────────
# If set AND no CF header is present, the api treats every request as this user.
DEV_TRUSTED_EMAIL=
